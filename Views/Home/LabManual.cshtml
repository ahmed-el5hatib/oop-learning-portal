                        <pre class="bg-dark text-light p-3 rounded font-mono border border-secondary" style="font-size: 0.85rem; max-height: 250px; overflow-y: auto;">
using System;

class Circle
{
    protected double radius; // protected fields are directly accessible by child classes

    public Circle(double radius)
    {
        this.radius = radius;
    }

    public virtual double GetArea()
    {
        return Math.PI * radius * radius;
    }
}

class Cylinder : Circle
{
    private double height;

    // calling parent class constructor via 'base'
    public Cylinder(double radius, double height) : base(radius)
    {
        this.height = height;
    }

    // overriding the parent GetArea method
    public override double GetArea()
    {
        return 2 * Math.PI * radius * (radius + height); // Cylinder surface area
    }

    public double GetVolume()
    {
        return base.GetArea() * height; // base area (parent) * height
    }
}</pre>
