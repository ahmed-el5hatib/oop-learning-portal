                        <p class="text-white-50 small">Write a recursive program to calculate the factorial of a given number, demonstrating call stack accumulation.</p>
                        <h6 class="Cairo-bold text-cyan mt-3"><i class="fa-solid fa-info-circle me-1"></i> Key Takeaway</h6>
                        <ul class="text-white-50 small font-outfit ps-3">
                            <li><strong>Base Case:</strong> <code>if (n == 0 || n == 1) return 1;</code> prevents infinite recursion loops and stack overflow.</li>
                        </ul>
                    </div>
                    <div class="col-lg-7">
                        <pre class="bg-dark text-light p-3 rounded font-mono border border-secondary" style="font-size: 0.85rem; max-height: 250px; overflow-y: auto;">
using System;

class Program
{
    // Recursive method to calculate factorial
    static int Factorial(int n)
    {
        if (n <= 1) return 1; // Base case to stop recursion
        return n * Factorial(n - 1); // Calling the function recursively with a smaller value
    }

    static void Main()
    {
        int num = 5;
        Console.WriteLine($"Factorial of {num} is: {Factorial(num)}"); // Output: 120
    }
}</pre>
