                    <div class="col-lg-7">
                        <pre class="bg-dark text-light p-3 rounded font-mono border border-secondary" style="font-size: 0.85rem; max-height: 250px; overflow-y: auto;">
using System;

enum OrderStatus
{
    Pending,
    Processing,
    Shipped,
    Delivered,
    Canceled
}

class Program
{
    static void Main()
    {
        OrderStatus currentOrder = OrderStatus.Shipped;

        // Using Enums with a switch statement
        switch (currentOrder)
        {
            case OrderStatus.Pending:
                Console.WriteLine("Order is awaiting review.");
