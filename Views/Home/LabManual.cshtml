<script>
    function filterLabManual() {
        const input = document.getElementById("manualSearchInput").value.toLowerCase();
        const items = document.querySelectorAll(".lab-item");

        items.forEach(item => {
            const keywords = item.getAttribute("data-keywords").toLowerCase();
            const title = item.querySelector("h4").innerText.toLowerCase();
            if (keywords.includes(input) || title.includes(input)) {
                item.style.display = "block";
            } else {
                item.style.display = "none";
            }
        });
    }

    function filterCategory(cat, btn) {
        // Toggle active button
        const buttons = document.querySelectorAll(".filter-btn");
        buttons.forEach(b => {
            b.classList.remove("active");
            b.classList.remove("btn-cyan");
            b.classList.add("btn-outline-secondary");
            b.classList.add("text-light");
        });
        btn.classList.add("active");
        btn.classList.add("btn-cyan");
        btn.classList.remove("btn-outline-secondary");
        btn.classList.remove("text-light");

        const items = document.querySelectorAll(".lab-item");
        items.forEach(item => {
            const itemCat = item.getAttribute("data-category");
            if (cat === "all" || itemCat === cat) {
                item.style.display = "block";
            } else {
                item.style.display = "none";
            }
        });
    }

    function tryCodeInPlayground(programId, sectionId) {
        // Find C# code of the clicked card
        const card = event.target.closest(".lab-item");
        if (card) {
            const pre = card.querySelector("pre");
            if (pre) {
                const code = pre.innerText;
                if (typeof window.loadIntoPlayground === "function") {
                    window.loadIntoPlayground(code, sectionId);
                } else {
                    localStorage.setItem("playground_injected_code", code);
                    window.location.href = "/Section/" + sectionId + "#playground";
                }
            }
        }
    }
</script>
